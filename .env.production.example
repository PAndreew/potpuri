POSTGRES_DB=potpuri
POSTGRES_USER=potpuri
POSTGRES_PASSWORD=replace-with-random-password
POTPURI_ENCRYPTION_KEY=replace-with-base64-32-byte-key
POTPURI_SESSION_SECRET=replace-with-base64-32-byte-secret
POTPURI_PUBLIC_URL=https://potpuri.example.com

# Cloudflare R2 — optional; when set, file/photo content is stored encrypted in R2
# instead of Postgres. Blobs uploaded without these vars stay in Postgres (fallback).
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
# Shared only with the separate Potpuri Feed service.
POTPURI_FEED_SERVICE_TOKEN=
# HMAC secret shared with Feed for validating 15-minute browser credentials.
POTPURI_FEED_SIGNING_SECRET=
